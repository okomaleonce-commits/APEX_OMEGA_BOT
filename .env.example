# ─── TELEGRAM ───────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token
CHAT_ID=your_telegram_chat_id

# ─── DATA SOURCES ────────────────────────────────────────────
API_FOOTBALL_KEY=your_apifootball_key
FOOTYSTATS_KEY=your_footystats_key
ODDS_API_KEY=your_odds_api_key
ODDS_API_BOOKMAKERS=Bet365,Pinnacle

# ─── STORAGE (Render Persistent Disk) ────────────────────────
DB_PATH=/var/data/apex_signals.db
DATA_DIR=/var/data

# ─── BOT CONFIG ───────────────────────────────────────────────
BANKROLL=1000
DEFAULT_MODE=safe
SCAN_HOURS_AHEAD=24
